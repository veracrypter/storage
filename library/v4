                    local List = {
                        Values = {},

                        Exclude = Parameters.Exclude,

                        Section = Self,
                        Window = Window
                    }


                    -- Renders
                    do
                        Menu.Draw("Frame", { Parent = Self.Frame, Size = NewUDim2(1, 0, 0, Size), BackgroundTransparency = 1, BorderSizePixel = 0 })

