                                    local KeyMode = KeybindModes[i]

                                    local IsValue = KeyMode == Keybind.Mode


                                    local ModeFrame = Menu.Draw("Frame", { Parent = BindFrame, Size = NewUDim2(1, 0, 0, 0), BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = BindFrame.ZIndex + 1, Name = "Holder" })
                                    local ModeButton = Menu.Draw("TextButton", { Parent = ModeFrame, Position = NewUDim2(0, 3, 0, 0), Size = NewUDim2(1, -3, 1, 0), TextColor3 = Theme["Text Color"][IsValue and "A" or "B"], TextXAlignment = "Left", BackgroundTransparency = 1, BorderSizePixel = 0, Text = KeyMode, TextTransparency = 1, ZIndex = ModeFrame.ZIndex + 1 })


                                    do
                                        Library.Colors[ModeButton] = { { "TextColor3", "Text Color", IsValue and "A" or "B" } }
                                    end


                                    do
                                        Connections[#Connections + 1] = ModeButton.MouseButton1Down:Connect(function()
                                            local NewActive = KeyMode == "Always On" or KeyMode == "Off Hold"

                                            SelectorLabel.Text = KeyMode

                                            Keybind.Mode = KeyMode
                                            Keybind.Active = NewActive

                                            Keybind.Updated()
                                            Changed(Keybind.Value, NewActive)

                                            local ModeButtons = Binds.ModeButtons

                                            for k = 1, #ModeButtons do
                                                local CurrentButton = ModeButtons[k]

                                                local ButtonIsSelected = CurrentButton == ModeButton

                                                Menu.Tween(CurrentButton, NewTweenInfo(0.15, Enum.EasingStyle.Linear), { TextColor3 = Theme["Text Color"][ButtonIsSelected and "A" or "B"] })

                                                do
                                                    Library.Colors[CurrentButton] = { { "TextColor3", "Text Color", ButtonIsSelected and "A" or "B" } }
                                                end
                                            end
                                        end)

                                        Connections[#Connections + 1] = ModeButton.MouseEnter:Connect(function()
                                            if Keybind.Mode ~= KeyMode then
                                                Menu.Tween(ModeButton, NewTweenInfo(0.15, Enum.EasingStyle.Linear), { TextColor3 = Theme["Text Color"].A })
                                            end
                                        end)

                                        Connections[#Connections + 1] = ModeButton.MouseLeave:Connect(function()
                                            if Keybind.Mode ~= KeyMode then
                                                Menu.Tween(ModeButton, NewTweenInfo(0.15, Enum.EasingStyle.Linear), { TextColor3 = Theme["Text Color"].B })
                                            end
                                        end)
                                    end


                                    Binds.ModeButtons[i] = ModeButton
                                end
                            end


                            do
                                local Descendants = Menu.GetDescendants(BindFrame)

                                for i = 1, #Descendants do
                                    local Descendant = Descendants[i]

                                    local Properties = { BackgroundTransparency = 0 }

                                    if Descendant.Name == "Holder" then
                                        continue
                                    elseif Descendant == BindFrame then
                                        Properties["Size"] = NewUDim2(1, 0, 0, 18 * Amount)
                                    elseif IsA(Descendant, "TextButton") then
                                        Properties = { TextTransparency = 0 }
                                    elseif IsA(Descendant, "UIStroke") then
                                        Properties = { Transparency = 0 }
                                    elseif IsA(Descendant, "UIGradient") or IsA(Descendant, "UIListLayout") then
                                        continue
                                    end

                                    Menu.Tween(Descendant, NewTweenInfo(0.1, Enum.EasingStyle.Linear), Properties)
                                end
                            end
                        end

                        function Binds.Close()
                            if not Binds.IsOpen then return end


                            Binds.IsOpen = false


                            local BindFrame = Binds["Frame"]


                            do
                                local Descendants = Menu.GetDescendants(BindFrame)

                                for i = 1, #Descendants do
                                    local Descendant = Descendants[i]

                                    local Properties = { BackgroundTransparency = 1 }

                                    if Descendant == BindFrame then
                                        Properties["Size"] = NewUDim2(1, 0, 0, 0)
                                    elseif IsA(Descendant, "TextButton") then
                                        Properties = { TextTransparency = 1 }
                                    elseif IsA(Descendant, "UIStroke") then
                                        Properties = { Transparency = 1 }
                                    elseif IsA(Descendant, "UIGradient") or IsA(Descendant, "UIListLayout") then
                                        continue
                                    end

                                    Menu.Tween(Descendant, NewTweenInfo(0.1, Enum.EasingStyle.Linear), Properties)
                                end
                            end


                            Delay(0.1, function()
                                Menu.Remove(BindFrame)
                            end)
                        end
                    end


                    do
                        Connections[#Connections + 1] = Button.MouseButton1Down:Connect(function()
                            Keybind.SetPickable(not Keybind.IsSelecting)
                        end)

                        Connections[#Connections + 1] = Button.MouseButton2Down:Connect(Keybind.Open)

                        Connections[#Connections + 1] = Section.Frame:GetPropertyChangedSignal("CanvasPosition"):Connect(Keybind.Close)
                        Connections[#Connections + 1] = Section.Frame:GetPropertyChangedSignal("AbsolutePosition"):Connect(Keybind.Close)

                        Connections[#Connections + 1] = UserInputService.InputBegan:Connect(function(Input, GPE)
                            local Value = Keybind.Value

                            if not Keybind.IsSelecting and Value[1] and Value[2] then
                                if Input.KeyCode == Enum[Value[1]][Value[2]] or Input.UserInputType == Enum[Value[1]][Value[2]] then
                                    if Keybind.Mode == "Always On" then return end
                                    if Self.Value == false then return end

                                    local NewActive = true

                                    if Keybind.Mode == "Toggle" then
                                        NewActive = not Keybind.Active
                                    elseif Keybind.Mode == "Off Hold" then
                                        NewActive = false
                                    end

                                    Keybind.Active = NewActive

                                    Keybind.Updated()
                                    Changed(Value, NewActive)

                                    if NewActive then
                                        Activated()
                                    end
                                end
                            end
                        end)

                        Connections[#Connections + 1] = UserInputService.InputEnded:Connect(function(Input, GPE)
                            if GPE then return end

                            local Value = Keybind.Value

                            if not Keybind.IsSelecting and Value[1] and Value[2] then
                                if Input.KeyCode == Enum[Value[1]][Value[2]] or Input.UserInputType == Enum[Value[1]][Value[2]] then
                                    if Keybind.Mode == "Toggle" or Keybind.Mode == "Always On" then return end

                                    local NewActive = false

                                    if Keybind.Mode == "Off Hold" then
                                        NewActive = true
                                    end

                                    Keybind.Active = NewActive

                                    Keybind.Updated()
                                    Changed(Value, NewActive)

                                    if NewActive then
                                        Activated()
                                    end
                                end
                            end
                        end)
                    end


                    if Flag then
                        if Category then
                            if typeof(Flags[Category]) == "table" then
                                Flags[Category][Flag] = Keybind
                            else
                                Flags[Category] = {
                                    [Flag] = Keybind
                                }
                            end
                        else
                            Flags[Flag] = Keybind
                        end
                    end


                    Keybind.SetKeyFromInput(Default)

                    Self.Bind = Keybind

                    if not Self.Value then
                        Self.Set(Mode == "Always On" or Mode == "Off Hold")
                    end

                    Window.Keybinds[#Window.Keybinds + 1] = Keybind
                    Section.Keybinds[#Section.Keybinds + 1] = Keybind
                    Self.Keybinds[#Self.Keybinds + 1] = Keybind

                    return Self, Keybind
                end

                function Elements.Show(Self)
                    local Section = Self.Section

                    if Self.IsVisible then return end

                    Self["Outline"].Visible = true
                    Self.IsVisible = true

                    Section.Offset += (Self.Expandable and Self.FullOffset or Self.Offset)
                    Section:Update()
                end

                function Elements.Hide(Self)
                    local Section = Self.Section

                    if not Self.IsVisible then return end

                    Self["Outline"].Visible = false
                    Self.IsVisible = false

                    Section.Offset -= (Self.Expandable and Self.FullOffset or Self.Offset)
                    Section:Update()
                end

                function Elements.Remove(Self)
                    local Section = Self.Section
                    local Window = Self.Window

                    local Keybinds = Self.Keybinds
                    local KeybindsList = Window.KeybindsList

                    Menu.Remove(Self["Outline"])

                    if Keybinds then
                        for i = 1, #Keybinds do
                            local Keybind = Keybinds[i]

                            if Keybind then
                                if KeybindsList then
                                    KeybindsList.Remove(Keybind)
                                end

                                Remove(Window.Keybinds, Find(Window.Keybinds, Keybind))
                            end
                        end
                    end

                    Section.Offset -= (Self.Expandable and Self.SectionOffset + 15 or Self.Offset)
                    Section:Update()
                end
            end


            Menu.Library = Library

            Menu.Init(Library)
        end
    end)()
end

return Menu
