                        Menu.Draw("Frame", { Parent = Outline, Position = NewUDim2(1, -14, 0, 0), Size = NewUDim2(0, 1, 1, 0), BackgroundColor3 = NewRGB(56, 56, 56), BorderSizePixel = 0, ZIndex = Inline.ZIndex - 1 })

                        local Holder = Menu.Draw("Frame", { Parent = Inline, Position = NewUDim2(0, 56, 0, 0), Size = NewUDim2(1, -69, 1, 0), BackgroundTransparency = 1, BorderSizePixel = 0, ClipsDescendants = true })

                        local Highlight = Menu.Draw("Frame", { Parent = Holder, Position = NewUDim2(0, 0, 0, 2), Size = NewUDim2(1, 0, 0, 11), BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = Inline.ZIndex - 1 })

