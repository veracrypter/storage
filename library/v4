                        Connections[#Connections + 1] = Plus.MouseButton1Down:Connect(function()
                            Slider.Set(Slider.Value + (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 1 / Decimals or 1))

                            LastDown = Tick() + 0.3
                            MouseDown2 = true
                        end)

                        Connections[#Connections + 1] = Button.MouseButton1Down:Connect(function()
