                                if MouseDown1 then
                                    MouseDown1 = false

                                    Slider.Refresh()
                                end

                                if MouseDown2 then
                                    MouseDown2 = false
                                end

                                if MouseDown3 then
                                    MouseDown3 = false
                                end
                            end
                        end

                        Library.InputChanged[#Library.InputChanged + 1] = function(Input)
                            if Input.UserInputType == Enum.UserInputType.MouseMovement and MouseDown1 then
                                Slider.Refresh()
                            end
                        end

                        Library.RenderStepped[#Library.RenderStepped + 1] = function()
                            if (not MouseDown2 and not MouseDown3) then return end

                            if (Tick() - LastDown) < 0.15 then return end

                            if MouseDown2 then
                                Slider.Set(Slider.Value + (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 1 / Decimals or 1))
                            elseif MouseDown3 then
                                Slider.Set(Slider.Value - (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 1 / Decimals or 1))
                            end

                            LastDown = Tick()
                        end

                        if not IsSection then
                            Connections[#Connections + 1] = MainFrame:GetPropertyChangedSignal("ScrollingEnabled"):Connect(function()
                                Button.Size = NewUDim2(1, MainFrame.ScrollingEnabled and -8 or -4, 0, 11)
                            end)
                        end
                    end


                    SetMetaTable(Slider, Elements)


                    Slider.Set(Default, false)


                    if Flag then
                        if Category then
                            if typeof(Flags[Category]) == "table" then
                                Flags[Category][Flag] = Slider
                            else
                                Flags[Category] = {
                                    [Flag] = Slider
                                }
                            end
                        else
                            Flags[Flag] = Slider
                        end
                    end


                    if Hidden then
                        Slider:Hide()
                    else
                        Slider:Show()
                    end

                    return Slider
                end

