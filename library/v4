                    local Minus = Slider["Minus"]
                    local Plus = Slider["Plus"]


                    -- Functions
                    do
                        function Slider.Get()
                            return Slider.Value
                        end

                        function Slider.Set(Value, Fire)
                            Slider.Value = Clamp(Round(Value * Slider.Decimals) / Slider.Decimals, Slider.Min, Slider.Max)

                            local NewValue = Slider.Value

                            local Special = false

                            if Specials then
                                for i = 1, #Specials do
                                    local Value = Specials[i]

                                    if NewValue == Value[2] then
                                        Special = Value[1]

                                        break
                                    end
                                end
                            end

                            Button2.Size = NewUDim2(((NewValue - Slider.Min) / (Slider.Max - Slider.Min)), 0, 1, 0)

                            Label.Text = Special or NewValue .. Prefix

                            if Fire ~= false then
                                Callback(Slider.Value)
                            end
                        end
                        
                        function Slider.SetMax(NewMax)
                            Slider.Max = NewMax
                            Slider.Value = Clamp(Slider.Value, Slider.Min, Slider.Max)
                            Button2.Size = NewUDim2(((Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)), 0, 1, 0)
                            
                            local Special = false
                            
                            if Specials then
                                for Index = 1, #Specials do
                                    local SpecialValue = Specials[Index]
                                    
                                    if Slider.Value == SpecialValue[2] then
                                        Special = SpecialValue[1]
                                        break
                                    end
                                end
                            end
                            
                            Label.Text = Special or Slider.Value .. Prefix
                        end

                        function Slider.Refresh()
                            local AbsoluteX = Button.AbsoluteSize.X

                            local SliderMin = Slider.Min
                            local SliderMax = Slider.Max

                            Slider.Set(Clamp(SliderMin + (SliderMax - SliderMin) * (Clamp(Mouse.X - Button2.AbsolutePosition.X, 0, AbsoluteX) / AbsoluteX), SliderMin, SliderMax))

                            RenderStepped:Wait()
                        end
