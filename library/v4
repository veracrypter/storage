                        CodeBox["Outline"] = Frame

                        CodeBox["Box"] = Box
                        CodeBox["Holder"] = Inline

                        CodeBox["Column"] = Column
                        CodeBox["Highlight"] = Highlight
                    end


                    -- Localisation
                    local Box = CodeBox["Box"]
                    local Holder = CodeBox["Holder"]

                    local Column = CodeBox["Column"]
                    local Highlight = CodeBox["Highlight"]


                    -- Functions
                    do
                        function CodeBox.Get() end
                        function CodeBox.Set() end

                        function CodeBox.GetText()
                            return Box.Text
                        end

                        function CodeBox.SetText(Text)
                            if #Text >= 200000 then
                                Text = Sub(Text, 1, 199999)
                            end

                            Box.Text = Text
                        end

                        function CodeBox.GetLineNumber(CursorPosition)
                            local Text = Box.Text

                            local Line = 1
                            local Offset = 1

                            while true do
                                local Position = StringFind(Text, "\n", Offset)

                                if Position and Position < CursorPosition then
                                    Offset = Position + 1
                                    Line += 1
                                else
                                    break
                                end
                            end

                            return Line
                        end

                        function CodeBox.UpdateLines()
                            local LineFrames = CodeBox.LineFrames

                            for i = 1, #LineFrames do
                                Menu.Remove(LineFrames[i])
                            end

                            for i = 1, CodeBox.Lines do
                                CodeBox.LineFrames[i] = Menu.Draw("TextLabel", { Parent = Column, Position = NewUDim2(0, 24, 0, 16.5 * (i - 1)), BackgroundTransparency = 1, BorderSizePixel = 0, Text = i, TextColor3 = NewRGB(212, 212, 212), TextStrokeTransparency = 1, FontFace = Fonts["Consolas Bold"] })
                            end

                            CodeBox.UpdateSize()
                        end

                        function CodeBox.UpdateSize()
                            local Size = 16.5 * CodeBox.Lines

                            local Difference = Size - Holder.AbsoluteSize.Y
                            local CanUpdate = Difference > 0

                            Holder.ScrollingEnabled = CanUpdate
                            Holder.CanvasSize = NewUDim2(0, 0, 0, CanUpdate and Size or 0)
                        end
                    end


                    -- Input & Connections
                    do
                        Connections[#Connections + 1] = Box:GetPropertyChangedSignal("CursorPosition"):Connect(function()
                            local Line = CodeBox.GetLineNumber(Box.CursorPosition)

                            if Line then
                                Highlight.Position = NewUDim2(0, 0, 0, 2 + (16.5 * (Line - 1)))
                            end
                        end)

                        Connections[#Connections + 1] = Box:GetPropertyChangedSignal("Text"):Connect(function()
                            local OldLines = CodeBox.Lines
                            local NewLines = #Split(Box.Text, "\n")

                            CodeBox.Lines = NewLines

                            if OldLines ~= NewLines then
                                CodeBox.UpdateLines()
                            end
                        end)

                        Connections[#Connections + 1] = Box:GetPropertyChangedSignal("TextBounds"):Connect(CodeBox.UpdateSize)

                        Connections[#Connections + 1] = Holder:GetPropertyChangedSignal("AbsoluteCanvasSize"):Connect(function()
                            if Holder.ScrollingEnabled then
                                local Difference = Holder.CanvasSize.Y.Offset - Holder.AbsoluteSize.Y

                                if Holder.CanvasPosition.Y >= (Difference - 20) then
                                    Holder.CanvasPosition = NewVector2(0, Difference)
                                end
                            end
                        end)
                    end


                    CodeBox.SetText(Default)
                    CodeBox.UpdateLines()


                    SetMetaTable(CodeBox, Elements)


                    if Flag then
                        if Category then
                            if typeof(Flags[Category]) == "table" then
                                Flags[Category][Flag] = CodeBox
                            else
                                Flags[Category] = {
                                    [Flag] = CodeBox
                                }
                            end
                        else
                            Flags[Flag] = CodeBox
                        end
                    end


                    if Hidden then
                        CodeBox:Hide()
                    else
                        CodeBox:Show()
                    end

                    return CodeBox
                end

