                        local Gradient = Menu.Draw("UIGradient", { Parent = Inline, Color = NewColorSequence(Theme.Contrast.A, Theme.Contrast.B), Rotation = 90 })

                        local Background = Menu.Draw("ScrollingFrame", { Parent = Outline, Size = NewUDim2(1, 0, 0, Size - 23), Position = NewUDim2(0, 0, 0, 20), BackgroundTransparency = 1, BorderSizePixel = 0, VerticalScrollBarInset = "ScrollBar", MidImage = Images.Scrollbar, TopImage = Images.Scrollbar, BottomImage = Images.Scrollbar, ScrollBarImageColor3 = Theme.Accent.A, CanvasSize = EmptyUDim2, ScrollingEnabled = false, ScrollBarThickness = 2, ClipsDescendants = true, SmoothScroll = false, ScrollRate = 0.25 })

                        local ScrollOutline = Menu.Draw("Frame", { Parent = Outline, Position = NewUDim2(1, -3, 0, 19), Size = NewUDim2(0, 3, 0, Size - 20), BackgroundColor3 = Theme.Outline, BorderSizePixel = 0, ZIndex = Background.ZIndex - 1, Visible = false })

                        Menu.Draw("UIListLayout", { Parent = Inline, Padding = EmptyUDim, FillDirection = "Horizontal", HorizontalFlex = "Fill", VerticalFlex = "Fill" })

                        Menu.Draw("UIListLayout", { Parent = Background, Padding = NewUDim(0, 6), SortOrder = Enum.SortOrder.LayoutOrder })

                        -- Labels
                        do
                            for i = 1, Columns do
                                local Label = Menu.Draw("TextLabel", { Parent = Inline, Text = Rows[i], TextColor3 = Theme["Text Color"].A, BackgroundTransparency = 1, BorderSizePixel = 0 })

                                Library.Colors[Label] = { { "TextColor3", "Text Color", "A" } }
                            end
                        end

                        -- Colors
                        do
                            Library.Colors[Outline] = { { "BackgroundColor3", "Contrast", "A" }, { "BorderColor3", "Outline" } }
                            Library.Colors[Gradient] = { { "Color", "Contrast", { "A", "B" } } }
                            Library.Colors[Background] = { { "ScrollBarImageColor3", "Accent", "A" } }
                        end

                        List["Frame"] = Background
                        List["ScrollBar Outline"] = ScrollOutline
                    end


                    -- Localisaiton
                    local Frame = List["Frame"]
                    local ScrollBar = List["ScrollBar Outline"]


                    -- Functions
                    do
                        function List.Get() end
                        function List.Set() end

                        function List.GetValue()
                            return List.Chosen[2], List.Chosen
                        end

                        function List.SetValue(Index)
                            local Found = List.Find(Index)
                            local Chosen = List.Chosen

                            if Chosen then
                                if Chosen[2] == Index then return end

                                local Labels = Chosen[3]

                                for i = 1, #Labels do
                                    local Label = Labels[i]

                                    Menu.Tween(Label, NewTweenInfo(0.15, Enum.EasingStyle.Linear), { TextColor3 = Theme["Text Color"].A })

                                    Library.Colors[Label] = { { "TextColor3", "Text Color", "A" } }
                                end

                                List.Chosen = nil
                            end

                            if Found then
                                local Labels = Found[3]

                                for i = 1, #Labels do
                                    local Label = Labels[i]

                                    Menu.Tween(Label, NewTweenInfo(0.15, Enum.EasingStyle.Linear), { TextColor3 = Theme.Accent.A })

                                    Library.Colors[Label] = { { "TextColor3", "Accent", "A" } }
                                end

                                List.Chosen = Found

                                Callback(Index, Found)
                            end
                        end

                        function List.SetValues(Values)
                            List.Empty()

                            for i = 1, #Values do
                                local Data = Values[i]

                                List.Add(Data[1], { Unpack(Data, 2, Columns + 1) })
                            end
                        end

                        function List.EditValue(Value, Data)
                            local Found = List.Find(Value)

                            if Found then
                                local Labels = Found[3]

                                for Index, Value in next, Data do
                                    Labels[Index].Text = Value
                                end

                                List.Sort()
                            end
                        end

                        function List.EditValues(Values)
                            for i = 1, #Values do
                                local Data = Values[i]

                                local Found = List.Find(Data[1])

                                if Found then
                                    local Labels = Found[3]

                                    for Index, Value in next, Data do
                                        if Index == 1 then continue end

                                        Labels[Index - 1].Text = Value
                                    end
                                end
                            end

                            List.Sort()
                        end

                        function List.ShowValues(Values)
                            local ListValues = List.Values

                            for i = 1, #ListValues do
                                local Value = ListValues[i]

                                Value[1].Visible = Find(Values, Value[2]) and true or false
                            end

                            List.Update()
                        end

                        function List.Add(Index, Values)
                            if Find(Exclude, Index) then return end

                            local Amount = #List.Values

                            local Holder = Menu.Draw("Frame", { Parent = Frame, Size = NewUDim2(1, 0, 0, Amount == 0 and 13 or 12), BackgroundTransparency = 1, BorderSizePixel = 0, LayoutOrder = Amount })

                            local Button = Menu.Draw("TextButton", { Parent = Holder, Position = NewUDim2(0, 0, 0, -1), Size = NewUDim2(1, 0, 1, 3), Text = "", BackgroundTransparency = 1, BorderSizePixel = 0 })

                            local Labels = {}

                            local Value = { Holder, Index }

                            List.Values[Amount + 1] = Value


                            -- Columns
                            do
                                for i = 1, Columns do
                                    local Outline = Menu.Draw("Frame", { Parent = Holder, Position = NewUDim2(Scale * (i - 1), 0, 0, Amount == 0 and 3 or 2), Size = NewUDim2(Scale, 0, 0, 12), BorderSizePixel = 0, BackgroundTransparency = 1 })

                                    local Label = Menu.Draw("TextLabel", { Parent = Outline, AnchorPoint = NewVector2(0.5, 0.5), Position = NewUDim2(0.5, 1, 0.5, 0), Text = Values[i], BackgroundTransparency = 1, TextStrokeTransparency = 0, TextColor3 = Theme["Text Color"].A, RichText = true })

                                    Menu.Draw("Frame", { Parent = Outline, Position = NewUDim2(1, 1, 0, 0), Size = NewUDim2(0, 1, 1, 0), BackgroundColor3 = Theme.White, BorderColor3 = Theme.Black })

                                    Labels[#Labels + 1] = Label

                                    -- Colors
                                    do
                                        Library.Colors[Label] = { { "TextColor3", "Text Color", "A" } }
                                    end
                                end
                            end


                            -- Input & Connections
                            do
                                if Clickable then
                                    Connections[#Connections + 1] = Button.MouseButton1Down:Connect(function()
                                        List.SetValue(Index)
                                    end)
                                end

                                Connections[#Connections + 1] = Button.MouseEnter:Connect(function()
                                    if List.Chosen ~= Value then
                                        for i = 1, #Labels do
                                            Menu.Tween(Labels[i], NewTweenInfo(0.15, Enum.EasingStyle.Linear), { TextColor3 = Theme.Accent.A })
                                        end
                                    end
                                end)

                                Connections[#Connections + 1] = Button.MouseLeave:Connect(function()
                                    if List.Chosen ~= Value then
                                        for i = 1, #Labels do
                                            Menu.Tween(Labels[i], NewTweenInfo(0.15, Enum.EasingStyle.Linear), { TextColor3 = Theme["Text Color"].A })
                                        end
                                    end
                                end)
                            end


                            Value[3] = Labels

                            Added(Value)

                            List.Sort()

                            List.Update()
                        end

                        function List.Remove(Index)
                            local Found, Place = List.Find(Index)

                            if Found then
                                Menu.Remove(Found[1])

                                Remove(List.Values, Place)

                                List.Sort()

                                List.Update()
                            end
                        end

                        function List.Empty()
                            local Values = List.Values

                            for i = #Values, 1, -1 do
                                List.Remove(Values[i][2])
                            end

                            List.Chosen = nil
                        end

                        function List.Find(Index)
                            local Values = List.Values

                            for i = #Values, 1, -1 do
                                local This = Values[i]

                                if This[2] == Index then
                                    return This, i
                                end
                            end
                        end

                        function List.Sort()
                            local NewList, Indexes = Filter(List.Values)

                            for i = 1, #NewList do
                                local This = NewList[i]
                                local Element = This[1]

                                if Indexes then
                                    for k = 1, #Indexes do
                                        Element = Element[Indexes[k]]
                                    end
                                end

                                Element.LayoutOrder = i - 1
                            end
                        end

                        function List.Update()
                            local Amount = 0
                            local Values = List.Values

                            for i = 1, #Values do
                                if Values[i][1].Visible then
                                    Amount += 1
                                end
                            end

                            local Canvas = (18 * Amount) + 1
                            local CanUpdate = Canvas >= Frame.AbsoluteSize.Y

