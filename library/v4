            function Menu.ShadeColor(Color : Color3, Red : Number, Green : Number, Blue : Number)
                return NewRGB(
                    Round(Color.R * 255 * Red),
                    Round(Color.G * 255 * Green),
                    Round(Color.B * 255 * Blue)
                )
            end

            function Menu.CreateGradient(Start : Color3, End : Color3, Frames : Number)
                local Red = (End.R - Start.R) / Frames
                local Green = (End.G - Start.G) / Frames
                local Blue = (End.B - Start.B) / Frames

                local Gradients = {}

                for i = 1, Frames do
                    local Multiplier = i - 1

                    Gradients[i] = NewRGB(
                        Round((Start.R + (Red * Multiplier)) * 255),
                        Round((Start.G + (Green * Multiplier)) * 255),
                        Round((Start.B + (Blue * Multiplier)) * 255)
                    )
                end

                return Gradients
            end

            function Menu.GetGradientFrame(Start : Color3, End : Color3, Frame : Number, TotalFrames : Number)
                local Red = (End.R - Start.R) / TotalFrames
                local Green = (End.G - Start.G) / TotalFrames
                local Blue = (End.B - Start.B) / TotalFrames

                return NewRGB(
                    Round((Start.R + (Red * Frame)) * 255),
                    Round((Start.G + (Green * Frame)) * 255),
                    Round((Start.B + (Blue * Frame)) * 255)
                )
            end

