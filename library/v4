            function Menu.Config(Action : String, Method : String)
                if Action == "New" then
                    return WriteFile(Format("%s/%s.cfg", Menu.Folders.Configs, Method), Menu.Config("Get"))
                elseif Action == "Get" then
                    local List = {}

                    for Section, Values in next, Flags do
                        if typeof(Values.Get) == "function" then
                            if not Values.Exclude then
                                List[Section] = Values.Get()
                            end
                        else
                            List[Section] = {}

                            for Name, Value in next, Values do
                                if typeof(Value) == "table" and typeof(Value.Get) == "function" and not Value.Exclude then
                                    List[Section][Name] = Value.Get()
                                end
                            end
                        end
                    end

                    return JSONEncode(HttpService, List)
                elseif Action == "Load" then
                    local Path = Format("%s/%s.cfg", Menu.Folders.Configs, Method)

                    local Config = {}

                    pcall(function()
                        Config = JSONDecode(HttpService, IsFile(Path) and ReadFile(Path) or Method)
                    end)

                    for Section, Values in next, Config do
                        local Category = Flags[Section]

                        if Category then
                            if typeof(Category.Set) == "function" then
                                if not Category.Exclude then
                                    SetThreadIdentity(7)
                                    Category.Set(Values)
                                end
                            else
                                for Name, Value in next, Values do
                                    local Flag = Category[Name]

                                    if Flag and not Flag.Exclude then
                                        SetThreadIdentity(7)
                                        Flag.Set(Value)
                                    end
                                end
                            end
                        end
                    end

                    return Config
                elseif Action == "Save" then
                    local Path = Format("%s/%s.cfg", Menu.Folders.Configs, Method)

                    if IsFile(Path) then
                        return WriteFile(Path, Menu.Config("Get"))
                    end
                elseif Action == "Reset" then
                    local Path = Format("%s/%s.cfg", Menu.Folders.Configs, Method)

                    if IsFile(Path) then
                        return WriteFile(Path, "{}")
                    end
                elseif Action == "Delete" then
                    local Path = Format("%s/%s.cfg", Menu.Folders.Configs, Method)

                    if IsFile(Path) then
                        return DelFile(Path)
                    end
                elseif Action == "List" then
                    local List = {}
                    local Configs = ListFiles(Menu.Folders.Configs)

                    for i = 1, #Configs do
                        List[#List + 1] = Match(Configs[i], "([^/\\]+)%.cfg$")
                    end

                    return List
                elseif Action == "Load Autoload" then
                    local Path = Format("%s/AutoLoad.json", Menu.Folders.Configs)

                    if IsFile(Path) then
                        local Data = JSONDecode(HttpService, ReadFile(Path))

                        if Data then
                            local String = Data[Menu.Game]

                            if String then
                                Menu.Config("Load", String)

                                return String
                            end
                        end
                    end
                elseif Action == "Set Autoload" then
                    local Path = Format("%s/AutoLoad.json", Menu.Folders.Configs)

                    if IsFile(Path) then
                        local Data = JSONDecode(HttpService, ReadFile(Path))

                        if Data then
                            Data[Menu.Game] = Method

                            WriteFile(Format("%s/AutoLoad.json", Menu.Folders.Configs), JSONEncode(HttpService, Data))

                            return
                        end
                    end

                    WriteFile(Format("%s/AutoLoad.json", Menu.Folders.Configs), JSONEncode(HttpService, {
                        [Menu.Game] = Method
                    }))
                end
            end

            function Menu.Lua(Action : String, Name : String, Modules : Table)
                if Action == "List" then
                    local List = {}
                    local Scripts = ListFiles(Menu.Folders.Luas)

                    for i = 1, #Scripts do
                        local Script = Scripts[i]

                        local IsLua = StringFind(Script, "%.lua$")
                        local IsLuau = StringFind(Script, "%.luau$")

                        if IsLua or IsLuau then
                            local This = Match(Script, "([^/\\]+).lua")

                            if Name then
                                This = Format("%s%s", This, IsLua and ".lua" or ".luau")
                            end

                            List[#List + 1] = This
                        end
                    end

                    return List
                elseif Action == "Load" then
                    local Path = Format("%s/%s", Menu.Folders.Luas, Name)

                    if IsFile(Path) then
                        Menu.Lua("Unload", Name)

                        local Success, Module = pcall(function()
                            return LoadFile(Path)()
                        end)

                        if not Success then
                            warn(Format("[%s]: An error occured whilst loading this Lua.", Name))

                            return
                        end

                        if not Module then
                            warn(Format("[%s]: No valid module for this lua was found, skipping.", Name))

                            return
                        end

                        if not Module.Load then
                            warn(Format("[%s]: Function: 'Load' was not found, skipping.", Name))

                            return
                        end

                        local Success2 = xpcall(Module.Load, function(Message)
                            Spawn(error, Format("[%s]: %s", Name, Message))
                        end, Modules)

                        if Success2 then
                            Menu.LoadedLuas[Name] = Module
                        end
                    end
                elseif Action == "Unload" then
                    local Module = Menu.LoadedLuas[Name]

                    if Module then
                        if typeof(Module.Unload) == "function" then
                            Module.Unload(Modules)
                        else
                            warn(Format("[%s]: Function: 'Unload' was not found, skipping.", Name))
                        end

                        Menu.LoadedLuas[Name] = nil
                    end
                elseif Action == "Save" then
                    local Path = Format("%s/%s", Menu.Folders.Luas, Name)

                    if IsFile(Path) then
                        WriteFile(Path, Modules)
                    end
                elseif Action == "IsLoaded" then
                    return Menu.LoadedLuas[Name] and true or false
                end
            end

            function Menu.ConfigTheme(Action : String, Method : String, Other : Table)
                if Action == "New" then
                    return WriteFile(Format("%s/%s.json", Menu.Folders.Themes, Method), Menu.ConfigTheme("Get"))
                elseif Action == "Get" then
                    local List = {}

                    for Index, Value in next, Method or Menu.Theme do
                        local Type = typeof(Value)

                        if Type == "table" then
                            List[Index] = {}

                            for SubIndex, SubValue in next, Value do
                                local NewValue = SubValue

                                if typeof(SubValue) == "Color3" then
                                    NewValue = { SubValue.R, SubValue.G, SubValue.B, "IsRGB" }
                                end

                                List[Index][SubIndex] = NewValue
                            end
                        elseif Type == "Color3" then
                            List[Index] = { Value.R, Value.G, Value.B, "IsRGB" }
                        else
                            List[Index] = Value
                        end
                    end

                    return JSONEncode(HttpService, List)
                elseif Action == "Load" then
                    Menu.Library:SetTheme(Menu.ConfigTheme("Sanitate", Method), "All")
                elseif Action == "Save" then
                    local Path = Format("%s/%s", Menu.Folders.Themes, Method)

                    if IsFile(Path) then
                        return WriteFile(Path, Menu.ConfigTheme("Get", Other))
                    end
                elseif Action == "Delete" then
                    local Path = Format("%s/%s", Menu.Folders.Themes, Method)

                    if IsFile(Path) then
                        return DelFile(Path)
                    end
                elseif Action == "List" then
                    local List = {}
                    local Themes = ListFiles(Menu.Folders.Themes)

                    for i = 1, #Themes do
                        local This = Match(Themes[i], "([^/\\]+)%.json$")

                        if This then
                            List[#List + 1] = This .. ".json"
                        end
                    end

                    return List
                elseif Action == "Sanitate" then
                    local List = Menu.ConfigTheme("Decode", Method)


                    -- Accent
                    do
                        local Accent = typeof(List.Accent) == "table" and List.Accent or {}

                        if typeof(Accent.A) ~= "Color3" or typeof(Accent.B) ~= "Color3" then
                            Accent = Menu.GetAccents(NewRGB(60, 67, 120))
                        end

                        List.Accent = Accent
                    end


                    -- Tree
                    do
