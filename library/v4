                function Library:Fade(Self, NewVisible)
                    if Self.IsFading then return end

                    if Self.CloseContent then
                        Self:CloseContent({ Self.CurrentContent, Self.CurrentColorpicker })
                    end

                    local Outline = Self.Outline
                    local Callbacks = Self.Callbacks
                    local Cache = Self.Cache

                    Self.IsFading = true
                    Outline.Visible = true

                    if Callbacks then
                        for i = 1, #Callbacks do
                            local Callback = Callbacks[i]

                            if Callback[2] == "Early" then
                                Callback[1](NewVisible)
                            end
                        end
                    end

                    local Descendants = Menu.GetDescendants(Outline)
                    local TweenData = NewTweenInfo(0.25, Enum.EasingStyle.Linear)

                    for i = 1, #Descendants do
                        local Descendant = Descendants[i]
                        local Properties = TransparencyProperties[Descendant.ClassName]

                        if not Properties then continue end

                        local Data = Cache[Descendant] or {}
                        local TweenProperties = {}

                        for k = 1, #Properties do
                            local Property = Properties[k]

                            local Cached = Data[Property]
                            local Value = Cached or Descendant[Property]

                            if not Cached then
                                Data[Property] = Value
                            end

                            TweenProperties[Property] = NewVisible and Value or 1
                        end

                        Menu.Tween(Descendant, TweenData, TweenProperties)

                        Cache[Descendant] = Data
                    end

                    if NewVisible then
                        Clear(Self.Cache)
                    end

                    Delay(0.25, function()
                        Self.IsVisible = NewVisible
                        Self.IsFading = false

                        Outline.Visible = NewVisible

                        if Callbacks then
                            for i = 1, #Callbacks do
                                local Callback = Callbacks[i]

